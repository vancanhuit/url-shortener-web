# Allowlisting gitignore template for Go projects.
# Ignore everything, then allowlist specific files and patterns.

# Ignore everything
*

# Allow traversal into subdirectories
!*/

# Re-ignore known generated/dependency directories
node_modules/

# Git and GitHub
!.gitignore
!.gitkeep
!.gitattributes
!.github/
!.github/**

# Go source and modules
!**/*.go
!go.mod
!go.sum

# SQL migrations
!**/*.sql

# Node.js dependencies
!package.json
!package-lock.json

# Docker and compose
!.dockerignore
!Dockerfile
!compose.yaml
!compose.https.yaml

# Build and dev tools
!Makefile
!.editorconfig

# Dagger CI module
!dagger.json
!.dagger/
!.dagger/**

# Templates (HTML and CSS sources)
!templates/
!templates/**

# Static assets directory (build output is generated here)
!assets/

# Documentation
!README.md
!LICENSE
